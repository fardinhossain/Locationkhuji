# Set default behavior to automatically normalize line endings
* text=auto

# Enforce LF for all source and configuration files to ensure safe production builds and consistent deployments
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
